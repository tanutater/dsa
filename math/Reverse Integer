class Solution {
public:
    int reverse(int x) {
        if(x>=INT_MAX || x<=INT_MIN) return 0;
        long long ans=0;
        while(x!=0){
            int r=x%10;
            x=x/10;
            if(ans>INT_MAX/10 || ans<INT_MIN/10) return 0;
            ans=ans*10+r;
        }
        return ans;
    }
};
