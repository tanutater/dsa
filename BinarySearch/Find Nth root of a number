class Solution {
  public:
    int nthRoot(int n, int m) {
        // Code here
        if(m==0) return 0;
        if(n==1) return m;
        int ans=-1;
        int s=1;
        int e=m;
        while(s<=e){
            int mid=s+(e-s)/2;
            long long temp=1LL*pow(mid,n);
            if(temp==m){
                return mid;
            }
            else if(temp<m) s=mid+1;
            else{
                e=mid-1;
            }
        }
        return ans;
    }
};
