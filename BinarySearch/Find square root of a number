class Solution {
public:
    int mySqrt(int x) {
        int ans=0;
        int s=0;
        int e=x;
        while(s<=e){
            int mid=s+(e-s)/2;
            if(1LL*mid*mid<=x){
                ans=mid;
                cout<<ans<<" ";
                s=mid+1;
            }
            else{
                e=mid-1;
            }
        }
        return ans;
    }
};
