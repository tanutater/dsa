class Solution {
public:
    bool check(vector<int>& nums) {
        int pair=0;
        for(int i=1;i<nums.size();i++){
            if(nums[i-1]>nums[i]){
                pair++;
            }
        }
        int n=nums.size();
        if(nums[n-1]>nums[0]){
            pair++;
        }
        cout<<pair;
        if(pair<=1) return true;
        return false;
    }
};
