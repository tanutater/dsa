class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int zero=0;
        int i=0;
        int j=0;
        while(i<nums.size() && j<nums.size()){
            if(nums[i]==0){
                zero++;
                i++;
            }
            else{
                swap(nums[i],nums[j]);
                j++;
                i=j;
            }

        }
    }
};
