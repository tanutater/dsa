class Solution {
  public:
    int getSecondLargest(vector<int> &arr) {
        // code here
        int maxi=-1;
        int smaxi=-1;
        for(int i =0;i<arr.size();i++){
            if(arr[i]>maxi){
                smaxi=maxi;
                maxi=arr[i];
            }
            else if(arr[i]>smaxi && arr[i]!=maxi){
                smaxi=arr[i];
            }
        }
        return smaxi;
        
    }
};
