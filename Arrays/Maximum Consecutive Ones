class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int ans=0;
        int j=0;
        int i=0;
        int curr=0;
        while(i<nums.size()){
            if(nums[i]==1){
                curr++;
            }
            else if (nums[i]!=1){
                ans=max(ans,curr);
                curr=0;
            }
            i++;
        }
        ans=max(ans,curr);
        return ans;
    }
};
